# ── Foundry ──────────────────────────────────────────────────────────────────
FOUNDRY_PROJECT_ENDPOINT=https://<tu-proyecto>.services.ai.azure.com/api/projects/<id>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_SERVER_URL=https://tu-mcp-server.com/mcp        # o http://localhost:3000/mcp en local
MCP_SERVER_NAME=mi-mcp-server
# MCP_ALLOWED_TOOLS=tool_a,tool_b                   # opcional: limita las tools expuestas

# ── Agente ───────────────────────────────────────────────────────────────────
AGENT_NAME=mi-agente
AGENT_TEMPERATURE=0.2          # 0.0 = determinista, 1.0 = creativo
AGENT_MAX_TOKENS=2048

# ── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production
